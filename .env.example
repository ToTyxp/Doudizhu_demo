# =============================================================
# 这是个模板文件（git 追踪）。请勿把真实 key 放在这里！
# 复制本文件为 .env 然后填入你的真实 API key 和（可选）base_url。
# .env 已被 .gitignore 排除，不会进仓库。
#   cp .env.example .env
# =============================================================

# ---- Anthropic（克劳德 / 小克 角色用）----
ANTHROPIC_API_KEY=
# 可选：自定义 API 入口（走代理/中转时设；直连官方留空）
ANTHROPIC_BASE_URL=

# ---- OpenAI（GPT 哥 / GPT 弟 角色用）----
OPENAI_API_KEY=
# 可选：自定义 API 入口（OpenAI 兼容代理留空或填代理地址）
OPENAI_BASE_URL=

# ---- 阿里 DashScope（通义系列角色用，OpenAI 兼容协议）----
DASHSCOPE_API_KEY=
# 默认就是 https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- 全局调试开关（可选）----
# 把所有 LLM 请求/响应打到 stderr，方便调试 prompt
LLM_DEBUG=0
